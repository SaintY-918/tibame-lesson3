# ⚠️ 安全鐵律：只有 `VITE_` 前綴的變數會被打包進前端 bundle、等同公開資訊。
# 機敏值（JWT_SECRET、COOKIE_SECRET、DATABASE_URL、密碼等）絕不可加 VITE_ 前綴，
# 也絕不可放進任何前端讀得到的位置。

# Database
DATABASE_URL=postgresql://vms:vms@localhost:5432/vms?schema=public

# API
API_PORT=3000
WEB_ORIGIN=http://localhost:5174

# Auth
JWT_SECRET=replace-me-with-a-32-byte-random-string
JWT_EXPIRES_IN=8h
COOKIE_SECRET=replace-me-with-another-random-string

# Seed
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=admin12345

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
