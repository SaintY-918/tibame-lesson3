{
  "name": "tibame-lesson2",
  "version": "0.1.0",
  "description": "Vehicle management system (monorepo)",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n api,web -c blue,magenta \"npm run dev --workspace apps/api\" \"npm run dev --workspace apps/web\"",
    "dev:api": "npm run dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . && npm run lint --workspaces --if-present",
    "lint:fix": "eslint . --fix",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace apps/api",
    "test:web": "npm run test --workspace apps/web",
    "db:migrate": "npm run db:migrate --workspace apps/api",
    "db:reset": "npm run db:reset --workspace apps/api",
    "db:test:reset": "npm run db:test:reset --workspace apps/api",
    "db:studio": "npm run db:studio --workspace apps/api",
    "seed": "npm run seed --workspace apps/api",
    "seed:mock": "npm run seed:mock --workspace apps/api -- --yes",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3"
  }
}
